# Ansible-specific
*.retry
*.log
*.bak
*.orig
*.swp
*.tmp
.ansible

# Inventory: commit structure and sops-encrypted secrets, never plaintext host_vars
inventories/*/host_vars/*.yml
!inventories/*/host_vars/*.sops.yml

# Personal server notes, contains the origin IP and host internals
external-fixes.txt

# Logs
logs/*
*.log
*.log.*

# Vault files (plaintext or auto-generated, if not encrypted)
vault.yml
group_vars/*/vault.yml
host_vars/*/vault.yml

# Ignore compiled Python files
__pycache__/
*.pyc
*.pyo

# Ignore virtual environments
.venv/
venv/
ENV/
env/

# Ignore molecule testing directories
.molecule/

# Ignore SSH key files
*.pem
*.key
*.pub
.ssh/

# Ignore system-specific files
.DS_Store
Thumbs.db

# Ignore editor/project files
.idea/
.vscode/
*.code-workspace
